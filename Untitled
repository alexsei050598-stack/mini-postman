body {
    font-family: Arial;
    background: #1e1e1e;
    color: white;
}

.container {
    width: 800px;
    margin: 50px auto;
}

.request-box {
    display: flex;
    gap: 10px;
}

input, select, button {
    padding: 10px;
}

textarea {
    width: 100%;
    height: 100px;
    margin-top: 20px;
    background: #2e2e2e;
    color: white;
}

.response {
    margin-top: 20px;
    background: #2e2e2e;
    padding: 10px;
}